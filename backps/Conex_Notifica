// 1. Importações corretas para o Firebase Functions v2
const { onRequest } = require("firebase-functions/v2/https");
const { onSchedule } = require("firebase-functions/v2/scheduler"); // <--- ISSO RESOLVE O ERRO
const admin = require("firebase-admin");

admin.initializeApp();

// 2. O VIGIA AUTOMÁTICO (Cron Job)
exports.vigiaAgenda = onSchedule("every 1 mins", async (event) => {
  // Ajuste para o horário de Brasília (UTC-3)
  const agoraSP = new Intl.DateTimeFormat("pt-BR", {
    timeZone: "America/Sao_Paulo",
    year: "numeric", month: "2-digit", day: "2-digit",
    hour: "2-digit", minute: "2-digit", hour12: false
  }).formatToParts(new Date());

  const dia = agoraSP.find(p => p.type === 'day').value;
  const mes = agoraSP.find(p => p.type === 'month').value;
  const ano = agoraSP.find(p => p.type === 'year').value;
  const hora = agoraSP.find(p => p.type === 'hour').value;
  const min = agoraSP.find(p => p.type === 'minute').value;

  const dataHoje = `${ano}-${mes}-${dia}`;
  const horaAtual = `${hora}:${min}`;

  console.log(`Vigia rodando: ${dataHoje} às ${horaAtual}`);

  try {
    const tarefasRef = admin.firestore().collection("tarefas");
    // Busca tarefas de hoje que ainda não dispararam alerta
    const snap = await tarefasRef
      .where("dataString", "==", dataHoje)
      .where("alertaDisparado", "==", false)
      .get();

    // Busca o endereço (token) do seu celular que funcionou no teste manual
    const tokenDoc = await admin.firestore().collection("tokens_dispositivos").doc("meu_celular").get();
    
    if (!tokenDoc.exists || snap.empty) return null;
    
    const token = tokenDoc.data().token;

    for (const d of snap.docs) {
      const t = d.data();
      // Se o horário da tarefa chegou ou passou, envia o Push
      if (t.hora <= horaAtual) {
        await admin.messaging().send({
          notification: { 
            title: '⏰ Hora da Tarefa!', 
            body: t.descricao 
          },
          token: token
        });
        // Marca como disparado para não enviar duplicado no próximo minuto
        await d.ref.update({ alertaDisparado: true });
        console.log(`Notificação enviada automaticamente: ${t.descricao}`);
      }
    }
  } catch (error) {
    console.error("Erro no Vigia:", error);
  }
});

// 3. Função de Teste Manual (A que você usou no link)
exports.enviarNotificacao = onRequest(async (req, res) => {
    try {
        const tokenDoc = await admin.firestore().collection("tokens_dispositivos").doc("meu_celular").get();
        if (!tokenDoc.exists) return res.status(404).send("Erro: Conecte o celular primeiro.");
        
        const message = {
            notification: { title: 'Teste de App Fechado! 🚀', body: 'O backend está nota 10!' },
            token: tokenDoc.data().token
        };
        await admin.messaging().send(message);
        res.send("Notificação disparada com sucesso para o app fechado!");
    } catch (e) { res.status(500).send("Erro: " + e.message); }
});